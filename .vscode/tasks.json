{
	// See https://go.microsoft.com/fwlink/?LinkId=733558
	// for the documentation about the tasks.json format
	"version": "2.0.0",
	"tasks": [
		{
            "label": "build-gcc",
            "type": "shell",
            "command": "make dgdb",
            "group":
			{
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "build-clang",
            "type": "shell",
            "command": "make dlldb",
            "problemMatcher": ["$gcc"]
        },
		{
			"label": "Build Project",
			"type": "shell",
			"command": "make",
            "problemMatcher": ["$gcc"]
		},
        {
            "label": "Build C GCC",
            "type": "shell",
            "command": "gcc",
            "args": [
                "-Wall",
                "-Wextra",
                "-Werror",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}"
            ]
        },
		{
            "label": "Build C Clang",
            "type": "shell",
            "command": "clang",
            "args": [
                "-Wall",
                "-Wextra",
                "-Werror",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}"
            ]
        }
    ]
}
